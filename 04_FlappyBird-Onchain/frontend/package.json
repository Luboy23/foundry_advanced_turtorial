{
  "name": "flappy-bird-onchain",
  "private": true,
  "version": "0.0.0",
  "description": "Flappy Bird on-chain frontend (React + Phaser + Vite).",
  "author": "lllu_23",
  "packageManager": "npm@11.5.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "analyze": "tsc -b && vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-query": "5.90.3",
    "phaser": "3.90.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1",
    "viem": "2.47.0",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "jsdom": "28.1.0",
    "rollup-plugin-visualizer": "6.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luboy23/foundry-advanced-04-flappy-bird-on-chain.git"
  },
  "bugs": {
    "url": "https://github.com/Luboy23/foundry-advanced-04-flappy-bird-on-chain/issues"
  },
  "homepage": "https://github.com/Luboy23/foundry-advanced-04-flappy-bird-on-chain"
}
