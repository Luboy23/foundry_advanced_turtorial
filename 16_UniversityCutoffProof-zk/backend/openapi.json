  "info": {
    "title": "UniversityCutoffProof-zk Backend",
    "description": "NestJS workbench backend for the admission demo",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "BackendSessionStatusDto": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "walletAddress": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string"
          },
          "devSignatureBypass": {
            "type": "boolean"
          }
        },
        "required": [
          "sessionId",
          "walletAddress",
          "role",
          "expiresAt",
          "devSignatureBypass"
        ]
      },
      "CreateChallengeDto": {
        "type": "object",
        "properties": {
          "walletAddress": {
            "type": "string"
          }
        },
        "required": [
          "walletAddress"
        ]
      },
      "AuthChallengeDto": {
        "type": "object",
        "properties": {
          "walletAddress": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          }
        },
        "required": [
          "walletAddress",
          "challenge",
          "expiresAt",
          "nonce"
        ]
      },
      "VerifyWalletDto": {
        "type": "object",
        "properties": {
          "walletAddress": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          }
        },
        "required": [
          "walletAddress",
          "challenge",
          "signature"
        ]
      },
      "WalletSessionDto": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "walletAddress": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string"
          },
          "devSignatureBypass": {
            "type": "boolean"
          }
        },
        "required": [
          "sessionId",
          "walletAddress",
          "role",
          "expiresAt",
          "devSignatureBypass"
        ]
      },
      "LogoutDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ]
      },
      "ScoreSourceInfoDto": {
        "type": "object",
        "properties": {
          "scoreSourceIdLabel": {
            "type": "string"
          },
          "sourceTitle": {
            "type": "string"
          },
          "maxScore": {
            "type": "number"
          },
          "merkleDepth": {
            "type": "number",
            "default": 20
          }
        },
        "required": [
          "scoreSourceIdLabel",
          "sourceTitle",
          "maxScore"
        ]
      },
      "ScoreRecordInputDto": {
        "type": "object",
        "properties": {
          "candidateLabel": {
            "type": "string"
          },
          "candidateIdHash": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "secretSalt": {
            "type": "string"
          },
          "boundStudentAddress": {
            "type": "string"
          }
        },
        "required": [
          "candidateLabel",
          "candidateIdHash",
          "score",
          "secretSalt",
          "boundStudentAddress"
        ]
      },
      "AuthorityImportPayloadDto": {
        "type": "object",
        "properties": {
          "scoreSource": {
            "$ref": "#/components/schemas/ScoreSourceInfoDto"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScoreRecordInputDto"
            }
          }
        },
        "required": [
          "scoreSource",
          "records"
        ]
      },
      "AuthorityDraftDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "scoreSourceIdLabel": {
            "type": "string"
          },
          "sourceTitle": {
            "type": "string"
          },
          "maxScore": {
            "type": "number"
          },
          "payloadJson": {
            "$ref": "#/components/schemas/AuthorityImportPayloadDto"
          },
          "createdBy": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "scoreSourceIdLabel",
          "sourceTitle",
          "maxScore",
          "payloadJson",
          "createdBy",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuthorityPublishHistoryItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "scoreSourceId": {
            "type": "string"
          },
          "scoreSourceIdLabel": {
            "type": "string"
          },
          "sourceTitle": {
            "type": "string"
          },
          "merkleRoot": {
            "type": "string"
          },
          "maxScore": {
            "type": "number"
          },
          "issuer": {
            "type": "string"
          },
          "issuedAt": {
            "type": "string"
          },
          "txHash": {
            "type": "object",
            "nullable": true
          },
          "blockNumber": {
            "type": "object",
            "nullable": true
          },
          "active": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "scoreSourceId",
          "scoreSourceIdLabel",
          "sourceTitle",
          "merkleRoot",
          "maxScore",
          "issuer",
          "issuedAt",
          "active",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuthorityIssuanceRecordDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "batchId": {
            "type": "string"
          },
          "scoreSourceIdLabel": {
            "type": "string"
          },
          "candidateLabel": {
            "type": "string"
          },
          "boundStudentAddress": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "fileName": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "batchId",
          "scoreSourceIdLabel",
          "candidateLabel",
          "boundStudentAddress",
          "score",
          "fileName",
          "createdAt"
        ]
      },
      "ScoreSourcePublicationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "scoreSourceId": {
            "type": "string"
          },
          "scoreSourceIdLabel": {
            "type": "string"
          },
          "sourceTitle": {
            "type": "string"
          },
          "merkleRoot": {
            "type": "string"
          },
          "maxScore": {
            "type": "number"
          },
          "issuer": {
            "type": "string"
          },
          "issuedAt": {
            "type": "string"
          },
          "txHash": {
            "type": "object",
            "nullable": true
          },
          "blockNumber": {
            "type": "object",
            "nullable": true
          },
          "active": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "scoreSourceId",
          "scoreSourceIdLabel",
          "sourceTitle",
          "merkleRoot",
          "maxScore",
          "issuer",
          "issuedAt",
          "active",
          "createdAt",
          "updatedAt"
        ]
      },
      "WorkbenchSyncStatusDto": {
        "type": "object",
        "properties": {
          "stale": {
            "type": "boolean"
          },
          "partialErrors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "stale",
          "partialErrors"
        ]
      },
      "AuthorityWorkbenchDto": {
        "type": "object",
        "properties": {
          "currentDraft": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthorityDraftDto"
              }
            ]
          },
          "publishHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorityPublishHistoryItemDto"
            }
          },
          "issuanceRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorityIssuanceRecordDto"
            }
          },
          "latestActiveSource": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ScoreSourcePublicationDto"
              }
            ]
          },
          "latestSource": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ScoreSourcePublicationDto"
              }
