{
  "name": "angrybirds-on-chain",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "levels:build": "node ../scripts/build-level-manifest.js",
    "stages:build": "npm run levels:build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test src/test/e2e/smoke.spec.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.3",
    "phaser": "^3.90.0",
    "planck": "^1.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "2.47.0",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
